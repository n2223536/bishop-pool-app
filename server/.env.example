# Bishop Estates Cabana Club API - Environment Variables

# Server Configuration
PORT=3001
NODE_ENV=development

# Authentication
# Generate a strong API key for production
ADMIN_API_KEY=bishop-admin-key-2024-secret

# JWT Secret for token-based auth
# Generate with: openssl rand -base64 32
JWT_SECRET=bishop-jwt-secret-change-in-production

# Venmo Configuration
VENMO_RECIPIENT=bishop-cabana-club

# Database (for future use when migrating from JSON)
# DATABASE_URL=postgresql://user:password@localhost:5432/bishop_cabana

# Email Configuration (for future use)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=notifications@bishop-cabana.com
# SMTP_PASSWORD=your-app-password

# Logging
LOG_LEVEL=info
